# Database connection string
# Local: postgresql://user@localhost:5432/community_portal?schema=public
# Production (Neon): postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user@localhost:5432/community_portal?schema=public"

# JWT secret for authentication (use a random string)
JWT_SECRET="your-jwt-secret-here"

# Email configuration (for registration approval emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Google Gemini API key (for AI features)
GEMINI_API_KEY=your-gemini-api-key

# Port 
PORT=4000
